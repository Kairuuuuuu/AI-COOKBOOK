        nextButton.setBackground(darkGreen);
        nextButton.setForeground(Color.WHITE);
        nextButton.setFont(new Font("SansSerif", Font.BOLD, 14));
        frame.add(nextButton);
        
        // 🌟 CHANGE 1: The Traffic Cop logic for the NEXT button
        nextButton.addActionListener(e -> {
        	frame.dispose();
            if (isForgotPassword) {
                ForgotPasswordScreen.showScreen();
            } else {
                
        	    SignUpScreen.showScreen(); // (Make sure this matches the exact name of your sign up class)
            }
        });
        
        JLabel loginText = new JLabel("<html>Already have an account? <b>Log in</b></html>", SwingConstants.CENTER);
        loginText.setFont(new Font("SansSerif", Font.PLAIN, 12));
        loginText.setForeground(darkGreen);
        loginText.setBounds(0, 750, 390, 20);
        loginText.setCursor(new Cursor(Cursor.HAND_CURSOR));
        
        loginText.addMouseListener(new MouseAdapter() {
            public void mousePressed(MouseEvent e) {
                frame.dispose();
                LoginScreen.main(new String[0]);
            }
        });
        frame.add(loginText);
        
        JLabel backToEmailScreen = new JLabel("← Back");
        backToEmailScreen.setFont(new Font("SansSerif", Font.BOLD, 15));
        backToEmailScreen.setForeground(darkGreen);
        backToEmailScreen.setBounds(10,106,390,20);
        backToEmailScreen.setCursor(new Cursor(Cursor.HAND_CURSOR)); // Added hand cursor here too so users know it's clickable!
       
        backToEmailScreen.addMouseListener(new MouseAdapter() {
        	public void mousePressed(MouseEvent e) {
        		frame.dispose();
                // 🌟 CHANGE 2: Fixed the typo! Passed the full variable name back.
        		EnterEmailScreen.showScreen(isForgotPassword);
        	}
        });
        frame.add(backToEmailScreen);

        frame.setVisible(true);
	}
}
